					<Item>l10n/th_TH/wilco_leader_alexander.vtt</Item>
				</ImportFiles>
			</Actions>
		</ActionGroup>
		<ActionGroup id="age-antiquity-current" scope="game" criteria="antiquity-age-current">
			<Actions>
				<UpdateArt>
					<Item>alexander</Item>
				</UpdateArt>
				<UpdateDatabase>
					<Item>data/greatworks.xml</Item>
