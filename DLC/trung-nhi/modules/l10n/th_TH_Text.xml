		<Replace Tag="LOC_PROMOTION_ARMY_TRUNG_NHI_LAC_REBELLION_NAME" Language="th_TH">
			<Text>กบฏลัก</Text>		<!-- Lạc Rebellion -->
		</Replace>
		<Replace Tag="LOC_PROMOTION_ARMY_TRUNG_NHI_LAC_REBELLION_DESCRIPTION" Language="th_TH">
			<Text>+3 พลังต่อสู้ สำหรับยูนิตบก ในรัศมีคำสั่งเมื่อมียูนิตศัตรูอย่างน้อย 2 หน่วยอยู่ติดกันกับ จึง นี [n]{LOC_PROMOTION_ARMY_TRUNG_NHI_ATTACK_DAMAGE_DESCRIPTION}</Text>		<!-- +3 Combat Strength for Land Units in the Command Radius when there are at least 2 enemy Units adjacent to Trung Nhi. [n]{LOC_PROMOTION_ARMY_TRUNG_NHI_ATTACK_DAMAGE_DESCRIPTION} -->
		</Replace>
		<Replace Tag="LOC_PROMOTION_ARMY_TRUNG_NHI_LAC_REBELLION_PREVIEW" Language="th_TH">
			<Text>+{1_Amount} กบฏลัก</Text>		<!-- +{1_Amount} Lạc Rebellion -->
		</Replace>
		<Replace Tag="LOC_PROMOTION_ARMY_TRUNG_NHI_ONE_SINGLE_CRY_NAME" Language="th_TH">
			<Text>เสียงร้องเดียว</Text>		<!-- One Single Cry -->
		</Replace>
		<Replace Tag="LOC_PROMOTION_ARMY_TRUNG_NHI_ONE_SINGLE_CRY_DESCRIPTION" Language="th_TH">
			<Text>+5 พลังต่อสู้ เมื่อโจมตีประสานและยิงเป้าหมายเดียว [n]{LOC_PROMOTION_ARMY_TRUNG_NHI_ATTACK_DAMAGE_FINAL_DESCRIPTION}</Text>		<!-- +5 Combat Strength with Coordinated Attack and Focus Fire. [n]{LOC_PROMOTION_ARMY_TRUNG_NHI_ATTACK_DAMAGE_FINAL_DESCRIPTION} -->
		</Replace>
		<Replace Tag="LOC_PROMOTION_ARMY_TRUNG_NHI_65_STRONGHOLDS_NAME" Language="th_TH">
			<Text>65 ป้อมปราการ</Text>		<!-- 65 Strongholds -->
		</Replace>
		<Replace Tag="LOC_PROMOTION_ARMY_TRUNG_NHI_65_STRONGHOLDS_DESCRIPTION" Language="th_TH">
			<Text>+5 พลังต่อสู้ กับเขตที่มีการป้องกันสำหรับยูนิตบก ในรัศมีคำสั่ง [n]{LOC_PROMOTION_ARMY_TRUNG_NHI_ATTACK_DAMAGE_DESCRIPTION}</Text>		<!-- +5 Combat Strength against Fortified Districts for Land Units in the Command Radius. [n]{LOC_PROMOTION_ARMY_TRUNG_NHI_ATTACK_DAMAGE_DESCRIPTION} -->
		</Replace>
		<Replace Tag="LOC_PROMOTION_ARMY_TRUNG_NHI_65_STRONGHOLDS_PREVIEW" Language="th_TH">
