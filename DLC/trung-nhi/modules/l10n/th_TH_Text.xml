		</Replace>
		<Replace Tag="LOC_PROMOTION_ARMY_TRUNG_NHI_JUNGLE_WARFARE_DESCRIPTION" Language="th_TH">
			<Text>+5 พลังต่อสู้ สำหรับยูนิตบก ในภูมิประเทศเขตร้อนในรัศมีคำสั่ง [n]{LOC_PROMOTION_ARMY_TRUNG_NHI_ATTACK_DAMAGE_DESCRIPTION}</Text>		<!-- +5 Combat Strength for Land Units in Tropical Terrain in the Command Radius. [n]{LOC_PROMOTION_ARMY_TRUNG_NHI_ATTACK_DAMAGE_DESCRIPTION} -->
		</Replace>
		<Replace Tag="LOC_PROMOTION_ARMY_TRUNG_NHI_METTLE_COURAGE_NAME" Language="th_TH">
			<Text>ความกล้าหาญและความอดทน</Text>		<!-- Mettle and Courage -->
		</Replace>
		<Replace Tag="LOC_PROMOTION_ARMY_TRUNG_NHI_METTLE_COURAGE_DESCRIPTION" Language="th_TH">
			<Text>+5 พลังต่อสู้ สำหรับยูนิตบก ในรัศมีคำสั่งเมื่ออยู่ในดินแดนฝ่ายเดียวกัน [n]{LOC_PROMOTION_ARMY_TRUNG_NHI_ATTACK_DAMAGE_DESCRIPTION}</Text>		<!-- +5 Combat Strength for Land Units in the Command Radius when in friendly territory. [n]{LOC_PROMOTION_ARMY_TRUNG_NHI_ATTACK_DAMAGE_DESCRIPTION} -->
		</Replace>
		<Replace Tag="LOC_PROMOTION_ARMY_TRUNG_NHI_METTLE_COURAGE_PREVIEW" Language="th_TH">
